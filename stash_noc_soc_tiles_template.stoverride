name: AI and Messaging Availability Tiles
desc: AI services, messaging platforms and media availability tiles for Stash

tiles:
  - name: tile-telegram
    title: Telegram
    content: Checking...
    icon: paperplane.fill
    interval: 600
    argument: Telegram|https://web.telegram.org|paperplane.fill

  - name: tile-whatsapp
    title: WhatsApp
    content: Checking...
    icon: phone.bubble.left
    interval: 600
    argument: WhatsApp|https://web.whatsapp.com|phone.bubble.left

  - name: tile-chatgpt
    title: ChatGPT
    content: Checking...
    icon: brain.head.profile
    interval: 600
    argument: ChatGPT|https://chatgpt.com|brain.head.profile

  - name: tile-claude
    title: Claude
    content: Checking...
    icon: sparkles
    interval: 600
    argument: Claude|https://claude.ai|sparkles

  - name: tile-gemini
    title: Gemini
    content: Checking...
    icon: diamond
    interval: 600
    argument: Gemini|https://gemini.google.com|diamond

  - name: tile-perplexity
    title: Perplexity
    content: Checking...
    icon: magnifyingglass.circle
    interval: 600
    argument: Perplexity|https://www.perplexity.ai|magnifyingglass.circle

  - name: tile-copilot
    title: Copilot
    content: Checking...
    icon: keyboard
    interval: 600
    argument: Copilot|https://copilot.microsoft.com|keyboard

  - name: tile-grok
    title: Grok
    content: Checking...
    icon: xmark.circle
    interval: 600
    argument: Grok|https://grok.com|xmark.circle

  - name: tile-poe
    title: Poe
    content: Checking...
    icon: message.circle
    interval: 600
    argument: Poe|https://poe.com|message.circle

  - name: tile-openrouter
    title: OpenRouter
    content: Checking...
    icon: arrow.triangle.branch
    interval: 600
    argument: OpenRouter|https://openrouter.ai|arrow.triangle.branch

  - name: tile-youtube
    title: YouTube
    content: Checking...
    icon: play.rectangle.fill
    interval: 600
    argument: YouTube|https://www.youtube.com|play.rectangle.fill

  - name: tile-netflix
    title: Netflix
    content: Checking...
    icon: tv
    interval: 600
    argument: Netflix|https://www.netflix.com|tv

script-providers:
  tile-telegram:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-whatsapp:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-chatgpt:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-claude:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-gemini:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-perplexity:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-copilot:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-grok:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-poe:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-openrouter:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-youtube:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-netflix:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400
