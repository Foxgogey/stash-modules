name: NOC/SOC Availability Tiles
desc: AI, Media and public Zabbix availability tiles for Stash

tiles:
  - name: tile-chatgpt
    title: ChatGPT
    content: Checking...
    icon: brain.head.profile
    interval: 600
    argument: ChatGPT|https://chatgpt.com|brain.head.profile

  - name: tile-claude
    title: Claude
    content: Checking...
    icon: sparkles
    interval: 600
    argument: Claude|https://claude.ai|sparkles

  - name: tile-gemini
    title: Gemini
    content: Checking...
    icon: diamond
    interval: 600
    argument: Gemini|https://gemini.google.com|diamond

  - name: tile-perplexity
    title: Perplexity
    content: Checking...
    icon: magnifyingglass.circle
    interval: 600
    argument: Perplexity|https://www.perplexity.ai|magnifyingglass.circle

  - name: tile-youtube
    title: YouTube
    content: Checking...
    icon: play.rectangle.fill
    interval: 600
    argument: YouTube|https://www.youtube.com|play.rectangle.fill

  - name: tile-netflix
    title: Netflix
    content: Checking...
    icon: tv
    interval: 600
    argument: Netflix|https://www.netflix.com|tv

  - name: tile-zabbix
    title: Zabbix
    content: Checking...
    icon: chart.bar.xaxis
    interval: 300
    argument: Zabbix|https://inno-zabbix.duckdns.org|chart.bar.xaxis

script-providers:
  tile-chatgpt:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-claude:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-gemini:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-perplexity:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-youtube:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-netflix:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400

  tile-zabbix:
    url: https://raw.githubusercontent.com/Foxgogey/stash-modules/main/stash_tile_check.js
    interval: 86400
